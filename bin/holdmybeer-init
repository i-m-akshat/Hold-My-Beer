#!/usr/bin/env bash
# holdmybeer-init script for macOS/Linux

target=$(pwd)
sdd_files=(".holdmybeer" ".gsd" "specify.md" "plan.md" "tasks.md" "SPEC.md" "PLAN.md")
found=()

for file in "${sdd_files[@]}"; do
  if [ -e "$target/$file" ]; then
    found+=("$file")
  fi
done

if [ ${#found[@]} -gt 0 ]; then
  echo -e "\033[1;33m🍺 [HoldMyBeer] SDD structure already detected in this directory:\033[0m"
  for f in "${found[@]}"; do
    echo "  - $f"
  done
  echo -e "\033[1;33mInitialization aborted to prevent overwriting existing work.\033[0m"
  exit 0
fi

echo -e "\033[1;36m🍺 Initializing HoldMyBeer SDD workspace...\033[0m"
mkdir -p "$target/.holdmybeer"

template_source="$HOME/.gemini/config/skills/holdmybeer-init/templates"
if [ ! -d "$template_source" ]; then
  template_source="$HOME/.claude/skills/holdmybeer-init/templates"
fi

if [ ! -d "$template_source" ]; then
  echo -e "\033[1;31mError: Could not locate HoldMyBeer templates at $template_source\033[0m"
  exit 1
fi

cp -r "$template_source"/* "$target/.holdmybeer/"

echo -e "\033[1;33m"
echo "  _    _       _     _ __  __       ____"
echo " | |  | |     | |   | |  \/  |     |  _ \\"
echo " | |__| | ___ | | __| | \  / | ___ | |_) | ___  ___ _ __"
echo " |  __  |/ _ \| |/ _\` | |\/| |/ _ \|  _ < / _ \/ _ \ '__|"
echo " | |  | | (_) | | (_| | |  | |  __/| |_) |  __/  __/ |"
echo " |_|  |_|\___/|_|\__,_|_|  |_|\___||____/ \___|\___|_|"
echo -e "\033[0m"

echo -e "\033[1;32m🍺 HoldMyBeer Workspace Initialized Successfully!\033[0m"
echo -e "\033[1;32mFiles created in .holdmybeer/:\033[0m"
echo "  + specify.md      (Requirement Specification Template)"
echo "  + plan.md         (Technical Phased Roadmap)"
echo "  + tasks.md        (Implementation Task Checklist)"
echo "  + constitution.md (Repository Standards & Rules)"
echo "  + dashboard.html  (Interactive HTML Workspace View)"
echo ""
echo -e "\033[1;36mOpen .holdmybeer/dashboard.html in your browser to view your SDD workspace dashboard!\033[0m"
